{
  "name": "attestor",
  "version": "0.1.0",
  "description": "Governance and proof engine for AI-assisted high-stakes workflows",
  "type": "module",
  "main": "dist/financial/cli.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/financial/financial.test.ts && tsx src/signing/signing.test.ts",
    "test:financial": "tsx src/financial/financial.test.ts",
    "test:signing": "tsx src/signing/signing.test.ts",
    "verify": "npm run typecheck && npm test && npm run build",
    "verify:full": "npm run verify && tsx tests/live-api.test.ts && tsx tests/live-postgres.test.ts && tsx tests/connectors-and-filing.test.ts && tsx tests/live-snowflake.test.ts",
    "test:live-api": "tsx tests/live-api.test.ts",
    "test:live-pg": "tsx tests/live-postgres.test.ts",
    "test:live-snowflake": "tsx tests/live-snowflake.test.ts",
    "start": "tsx src/financial/cli.ts",
    "list": "tsx src/financial/cli.ts list",
    "scenario": "tsx src/financial/cli.ts scenario",
    "benchmark": "tsx src/financial/cli.ts benchmark",
    "live": "tsx src/financial/cli.ts live-scenario",
    "prove": "tsx src/financial/cli.ts prove",
    "serve": "tsx src/service/api-server.ts",
    "verify:cert": "tsx src/signing/verify-cli.ts",
    "keygen": "tsx -e \"import{generateKeyPair,saveKeyPair}from'./src/signing/keys.js';const kp=generateKeyPair();saveKeyPair(kp,'.attestor/private.pem','.attestor/public.pem');console.log('Key pair generated:',kp.fingerprint)\""
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@napi-rs/keyring": "^1.2.0",
    "@types/node": "^22.0.0",
    "bullmq": "^5.73.0",
    "dotenv": "^17.0.0",
    "embedded-postgres": "^18.3.0-beta.16",
    "hono": "^4.12.10",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "openai": "^4.77.3",
    "openid-client": "^6.8.2",
    "pg": "^8.20.0",
    "redis-memory-server": "^0.16.0",
    "snowflake-sdk": "^2.3.6",
    "typescript": "^5.7.3",
    "xmlbuilder2": "^4.0.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "UNLICENSED",
  "private": true
}
