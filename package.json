    "@types/smtp-server": "^3.5.13",
    "bullmq": "^5.73.0",
    "cda-schematron-validator": "^1.1.12",
    "dotenv": "^17.0.0",
    "embedded-postgres": "^18.3.0-beta.16",
    "hono": "^4.12.10",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "jszip": "^3.10.1",
    "nodemailer": "^8.0.5",
    "openai": "^4.77.3",
    "openid-client": "^6.8.2",
    "pg": "^8.20.0",
    "redis-memory-server": "^0.16.0",
    "saxon-js": "^2.7.0",
    "smtp-server": "^3.18.4",
    "snowflake-sdk": "^2.3.6",
    "stripe": "^22.0.0",
    "typescript": "^5.7.3",
    "xmlbuilder2": "^4.0.3",
    "xslt3": "^2.7.0"
